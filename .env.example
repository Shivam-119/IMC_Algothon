# Copy this file to .env and fill in your credentials.
# .env is gitignored — never commit real credentials.

# ── Exchange ─────────────────────────────────────────────────────────────────
# Test exchange (for experimentation):
CMI_URL=http://ec2-52-49-69-152.eu-west-1.compute.amazonaws.com/
# Challenge exchange (uncomment when competing):
# CMI_URL=REPLACE_WITH_CHALLENGE_URL

# ── Auth ──────────────────────────────────────────────────────────────────────
CMI_USER=REPLACE_WITH_USERNAME
CMI_PASS=REPLACE_WITH_PASSWORD

# ── Optional: AeroDataBox RapidAPI key (for LHR flight products) ─────────────
# Get a free key at https://rapidapi.com/aedbx-aedbx/api/aerodatabox
# Leave blank to fall back to the exchange starting price for LHR products.
RAPIDAPI_KEY=
